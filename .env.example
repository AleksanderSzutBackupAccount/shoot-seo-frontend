# ─────────────────────────────────────────────────────────────────────────────
# Shoot SEO — frontend (Nuxt 4 BFF). Copy to `.env` for local dev.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the Laravel REST API the Nuxt BFF proxies to (server-side only).
# Local dev:  http://localhost:8000/api
# Production: set NUXT_API_BASE at runtime to the in-cluster API service, e.g.
#   NUXT_API_BASE=http://shoot-seo-api.shoot-seo.svc.cluster.local/api
# (Nuxt maps runtimeConfig.apiBase → the NUXT_API_BASE env var automatically.)
API_BASE=http://localhost:8000/api

# Port the Nuxt server listens on (prod container listens on 3000).
# PORT=3100
